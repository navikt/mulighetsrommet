{
  "name": "@arbeidsmarkedstiltak/flate",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "cross-env VITE_MULIGHETSROMMET_API_MOCK=true vite",
    "backend": "cross-env VITE_MULIGHETSROMMET_API_BASE='http://localhost:8080' vite",
    "lint": "eslint src --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint src --fix",
    "typecheck": "tsc",
    "build": "cross-env VITE_MULIGHETSROMMET_API_MOCK=true APP=MODIA vite build",
    "build:lokal": "cross-env APP=LOKAL VITE_MULIGHETSROMMET_API_MOCK=true vite build",
    "build:modia": "cross-env APP=MODIA VITE_MULIGHETSROMMET_API_BASE='/mulighetsrommet-api' vite build",
    "build:nav": "cross-env APP=NAV VITE_MULIGHETSROMMET_API_BASE='/mulighetsrommet-api' vite build",
    "preview": "APP=MODIA vite preview",
    "playwright": "playwright test",
    "playwright:debug": "playwright test --debug",
    "playwright:open": "playwright test --ui",
    "playwright:codegen": "playwright codegen playwright.dev"
  },
  "browserslist": [
    ">0.2%",
    "not dead",
    "not ie < 11",
    "not op_mini all"
  ],
  "dependencies": {
    "@arbeidsmarkedstiltak/api-client": "workspace:*",
    "@emotion/cache": "11.14.0",
    "@emotion/react": "11.14.0",
    "@grafana/faro-web-sdk": "2.8.0",
    "@mr/frontend-common": "workspace:*",
    "@navikt/aksel-icons": "8.14.0",
    "@navikt/ds-css": "8.14.0",
    "@navikt/ds-react": "8.14.0",
    "@navikt/ds-tailwind": "8.14.0",
    "@tailwindcss/postcss": "4.3.1",
    "@tailwindcss/vite": "4.3.1",
    "@tanstack/react-query": "5.101.2",
    "@tanstack/react-query-devtools": "5.101.2",
    "axe-core": "4.12.1",
    "classnames": "2.5.1",
    "dequal": "2.0.3",
    "jotai": "2.20.1",
    "jotai-location": "0.6.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-error-boundary": "6.1.2",
    "react-markdown": "10.1.0",
    "react-router": "7.17.0",
    "tailwindcss": "4.3.1",
    "uuid": "14.0.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@mr/eslint-config-react-app": "workspace:*",
    "@playwright/test": "1.61.1",
    "@tailwindcss/typography": "0.5.20",
    "@types/node": "25.9.3",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "cross-env": "10.1.0",
    "dotenv": "17.4.2",
    "eslint": "10.6.0",
    "msw": "2.14.6",
    "playwright": "1.61.1",
    "postcss-import": "16.1.1",
    "rollup-plugin-visualizer": "7.0.1",
    "sass-embedded": "1.100.0",
    "typescript": "6.0.3",
    "vite": "8.1.0"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
