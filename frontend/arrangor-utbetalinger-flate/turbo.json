{
  "extends": ["//"],
  "tasks": {
    "typegen": {
      "outputs": [".react-router"]
    },
    "typecheck": {
      "dependsOn": ["^build", "typegen"],
      "outputs": []
    },
    "build": {
      "dependsOn": ["^build", "typegen"],
      "outputs": ["build"]
    },
    "build:demo": {
      "dependsOn": ["^build", "typegen"],
      "outputs": ["build"]
    },
    "pack": {
      "env": ["NODE_AUTH_TOKEN", "NPM_CONFIG_USERCONFIG"],
      "dependsOn": ["build"],
      "outputs": ["dist"]
    },
    "pack:demo": {
      "env": ["NODE_AUTH_TOKEN", "NPM_CONFIG_USERCONFIG"],
      "dependsOn": ["build:demo"],
      "outputs": ["dist"]
    },
    "playwright": {
      "dependsOn": ["^build"],
      "outputs": []
    }
  }
}
