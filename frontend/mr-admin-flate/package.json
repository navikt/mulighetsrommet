{
  "name": "mr-admin-flate",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "cross-env VITE_MULIGHETSROMMET_API_MOCK=true vite",
    "backend": "cross-env VITE_MULIGHETSROMMET_API_BASE='http://localhost:8080' vite",
    "lint": "eslint src --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint src --fix",
    "typecheck": "tsc",
    "build": "cross-env VITE_MULIGHETSROMMET_API_BASE='/mulighetsrommet-api' VITE_FARO_URL=https://telemetry.nav.no/collect vite build",
    "build:lokal": "cross-env VITE_MULIGHETSROMMET_API_BASE='http://localhost:8080' VITE_FARO_URL=http://localhost:1234 vite build",
    "preview": "vite preview",
    "test": "vitest",
    "playwright": "playwright test",
    "playwright:debug": "playwright test --debug",
    "playwright:open": "playwright test --ui",
    "playwright:codegen": "playwright codegen playwright.dev"
  },
  "dependencies": {
    "@grafana/faro-web-sdk": "2.3.1",
    "@hookform/resolvers": "5.2.2",
    "@mr/frontend-common": "workspace:*",
    "@navikt/aksel-icons": "8.10.2",
    "@navikt/ds-css": "8.10.2",
    "@navikt/ds-react": "8.10.2",
    "@navikt/ds-tailwind": "8.10.2",
    "@portabletext/editor": "6.6.2",
    "@portabletext/toolbar": "7.0.25",
    "@portabletext/types": "4.0.2",
    "@tailwindcss/vite": "4.2.4",
    "@tanstack/react-query": "5.100.5",
    "@tanstack/react-query-devtools": "5.100.5",
    "@tiltaksadministrasjon/api-client": "workspace:*",
    "@unhead/react": "3.1.0",
    "dequal": "2.0.3",
    "highcharts": "12.6.0",
    "highcharts-react-official": "3.2.3",
    "jotai": "2.19.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "7.74.0",
    "react-router": "7.14.1",
    "react-select": "5.10.2",
    "uuid": "14.0.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.11.2",
    "@mr/eslint-config-react-app": "workspace:*",
    "@playwright/test": "1.59.1",
    "@tailwindcss/postcss": "4.2.4",
    "@tailwindcss/typography": "0.5.19",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "axe-core": "4.11.3",
    "cross-env": "10.1.0",
    "eslint": "10.2.1",
    "msw": "2.13.6",
    "playwright": "1.59.1",
    "postcss": "8.5.12",
    "tailwindcss": "4.2.4",
    "typescript": "6.0.3",
    "vite": "8.0.10",
    "vitest": "4.1.5"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
