    "@tailwindcss/typography": "0.5.20",
    "@types/node": "25.9.3",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "axe-core": "4.12.1",
    "cross-env": "10.1.0",
    "eslint": "10.5.0",
    "msw": "2.14.6",
    "playwright": "1.61.1",
    "postcss": "8.5.15",
    "tailwindcss": "4.3.1",
    "typescript": "6.0.3",
    "vite": "8.0.16",
    "vitest": "4.1.9"
