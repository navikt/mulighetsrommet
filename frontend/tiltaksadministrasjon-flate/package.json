    "@navikt/aksel-icons": "8.14.0",
    "@navikt/ds-css": "8.14.0",
    "@navikt/ds-react": "8.14.0",
    "@navikt/ds-tailwind": "8.14.0",
    "@portabletext/editor": "7.6.2",
    "@portabletext/toolbar": "8.0.21",
    "@portabletext/types": "4.0.2",
    "@tailwindcss/vite": "4.3.1",
    "@tanstack/react-query": "5.101.0",
    "@tanstack/react-query-devtools": "5.101.0",
    "@tiltaksadministrasjon/api-client": "workspace:*",
    "@unhead/react": "3.1.4",
    "dequal": "2.0.3",
    "highcharts": "13.0.0",
    "jotai": "2.20.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "7.80.0",
    "react-pdf": "^10.4.1",
    "react-router": "7.17.0",
    "uuid": "14.0.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.11.3",
